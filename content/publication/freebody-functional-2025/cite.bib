@article{freebody_functional_2025,
 abstract = {Functional near-infrared spectroscopy (fNIRS) was once confined to stationary, wired systems that limited studies to controlled laboratory environments. But today’s devices using this technology are lighter, wireless, and designed for true portability and clinical applicability. Ongoing research could change how the medical community views the utility of NIRS, expanding its use in neurodegenerative and neurodevelopmental disorders, rehabilitation, and psychiatry.},
 author = {Freebody, Marie},
 journal = {PHOTONICS Spectra},
 month = {November},
 title = {Functional Near-Infrared Spectroscopy Targets Changes in Brain Metabolism},
 url = {https://www.photonics.com/Articles/Functional-Near-Infrared-Spectroscopy-Targets/a71511},
 volume = {Nov/Dec 2025},
 year = {2025}
}

