 number = {1},
 pages = {e70319},
 shorttitle = {Effects of Electronic Sports on Community-Dwelling Older Adults With Mild Cognitive Impairment},
 title = {Effects of Electronic Sports on Community-Dwelling Older Adults With Mild Cognitive Impairment: A Randomized Controlled Study},
