@article{guler_beetroot_2026,
 abstract = {The ability of nitrate (NO₃⁻)-rich beetroot juice (BJ) to improve exercise depends on training status. However, the mechanisms are understudied. The aim of this study was to investigate the impact of acute BJ supplementation on the Special Judo Fitness Test (SJFT) outcomes in elite and recreational judokas.

Forty judo athletes (17 elite and 23 recreational) completed two SJFT sessions after drinking either BJ or a placebo in a randomized, double-blind, placebo-controlled crossover design. Plasma NO₃⁻ and lactate, tissue saturation index (TSI) and SJFT outcomes were measured. Plasma NO₃⁻ increased after BJ intake in both groups (p \textless 0.001). Elite athletes achieved more total throws (TT) (p \textless 0.05) and exhibited lower TSI during SJFT, 1-min post-SJFT heart rate (HR₁), and SJFT index (p \textless 0.05), but higher post-SJFT lactate and TSI than recreational athletes (p \textless 0.05). TT did not improve following supplementation (p \textgreater 0.05). BJ increased post-SJFT TSI (elite: 2.6 ± 3% vs. recreational: 4.55 ± 2.6%) and reduced HR₁ (elite: − 5.6 ± 3.3% vs. recreational: − 9.8 ± 4.7%) and SJFT index (elite: − 2.7 ± 5.6% vs. recreational: − 6 ± 5.8%) overall (p \textless 0.001 compared to placebo), with greater effects in recreational athletes (p \textless 0.05). BJ also decreased post-SJFT lactate only in recreational athletes (p \textless 0.01). Higher maximal oxygen uptake correlated with smaller BJ-induced improvements in lactate (r = − 0.57, p \textless 0.001), HR₁ (r = − 0.50, p \textless 0.001), SJFT index (r = − 0.43, p \textless 0.01), and TSI during the third period of SJFT effort (r = − 0.5, p \textless 0.001) and during 1-min recovery (r = − 0.35, p \textless 0.05). BJ primarily attenuates the physiological cost and enhances recovery-related markers during the judo performance, rather than directly increasing the performance, with responsiveness modulated by training status.},
 author = {Guler, Iskender and Sajedi, Heidar and Fidel, Burcu and Kaya, Erdi and Akpınar, Selahattin and Khodadadi, Davar and Laher, Ismail and Babaei, Mohammad},
 doi = {10.1038/s41598-026-52444-4},
 issn = {2045-2322},
 journal = {Scientific Reports},
 keywords = {PortaMon, CR},
 language = {en},
 month = {May},
 shorttitle = {Beetroot juice modulates physiological responses and accelerates recovery during the special judo performance},
 title = {Beetroot juice modulates physiological responses and accelerates recovery during the special judo performance: a randomized trial},
 urldate = {2026-06-11},
 year = {2026}
}

