 publisher = {Multidisciplinary Digital Publishing Institute},
 shorttitle = {The Priming Effect of Auxiliary Line Construction on Mathematical Creative Thinking},
 title = {The Priming Effect of Auxiliary Line Construction on Mathematical Creative Thinking: An fNIRS Study},
 url = {https://www.mdpi.com/2079-3200/14/3/40},
 urldate = {2026-05-08},
