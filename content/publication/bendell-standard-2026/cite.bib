 shorttitle = {Standard V̇ \textlessspan style="font-variant},
 title = {Standard V̇ o2 measures underestimate metabolic demand during blood flow-restricted exercise},
 url = {https://journals.physiology.org/doi/10.1152/japplphysiol.00715.2025},
